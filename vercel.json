{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "cd fleek-vto-prototype && npm install && npm run build",
  "outputDirectory": "fleek-vto-prototype/dist",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
