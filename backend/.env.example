# Copy to backend/.env and fill in.

# Supabase project (defaults baked into config.py point at the active
# hackathon project pcyiyxlnmqobowdsgmtl — override to use another, e.g.
# SUPABASE_PROJECT_REF=gnngtcvhqblmdxfknses with its matching key).
#SUPABASE_PROJECT_REF=pcyiyxlnmqobowdsgmtl
#SUPABASE_KEY=<publishable/anon key for that project>
#SUPABASE_BUCKET=garment-images

# Google Gemini — enables real AI try-on renders + buyer summaries.
# Without it the app still works: demo renderer + rule-based summaries.
GEMINI_API_KEY=
